generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Office {
  id                   String   @id @default(cuid())
  name                 String
  dpmsSystem           String   @default("OPEN_DENTAL")
  workingDays          String   @default("[]")
  timeIncrement        Int      @default(10)
  feeModel             String   @default("UCR")
  operatories          String   @default("[]")
  schedulingRules      String   @default("")
  alternateWeekEnabled Boolean  @default(false)
  rotationEnabled      Boolean  @default(false)
  rotationWeeks        Int      @default(2)
  schedulingWindows    String   @default("[]")
  // Sprint 1 — X-segment + practice-model metadata
  practiceModel            String  @default("1D2O")
  productionPolicy         String  @default("JAMESON_50")
  maxConcurrentDoctorOps   Int     @default(2)
  doctorTransitionBufferMin Int    @default(0)
  efdaScopeLevel           String  @default("NONE")
  // Sprint 5 — Intake V2 (see SPRINT-5-PLAN §3.1 / engine/types.ts IntakeGoals + IntakeConstraints).
  // JSON blobs; structure validated by zod in src/lib/contracts/api-schemas.ts.
  intakeGoals              String  @default("{}")
  intakeConstraints        String  @default("{}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  providers            Provider[]
  blockTypes           BlockType[]
  rules                ScheduleRule?
  templates            ScheduleTemplate[]
  scheduleVersions     ScheduleVersion[]
  advisories           TemplateAdvisory[]
  priorTemplates       PriorTemplate[]
}

model Provider {
  id              String  @id @default(cuid())
  officeId        String
  name            String
  role            String
  operatories     String  @default("[]")
  columns         Int     @default(1)
  workingStart    String  @default("07:00")
  workingEnd      String  @default("16:00")
  lunchStart      String  @default("12:00")
  lunchEnd        String  @default("13:00")
  lunchEnabled      Boolean @default(true)
  dailyGoal         Float   @default(0)
  color             String  @default("#666")
  seesNewPatients   Boolean @default(true)
  staggerOffsetMin  Int     @default(0)
  providerSchedule  String  @default("{}")
  currentProcedureMix String @default("{}")
  futureProcedureMix  String @default("{}")
  // Sprint 1 \u2014 day-of-week roster (JSON array e.g. ["MON","TUE","WED","THU"])
  // Sprint 4 P0-4: Bible \u00a77 makes roster first-class. Default is empty; the
  // generator refuses to place blocks for an empty-roster provider and emits
  // a warning. Provider intake must set this explicitly.
  dayOfWeekRoster   String  @default("[]")
  office            Office  @relation(fields: [officeId], references: [id], onDelete: Cascade)
  absences          ProviderAbsence[]

  @@index([officeId])
}

model BlockType {
  id            String  @id @default(cuid())
  officeId      String
  label         String
  description   String  @default("")
  minimumAmount Float   @default(0)
  appliesToRole String
  durationMin   Int     @default(30)
  durationMax   Int     @default(30)
  color         String  @default("#666")
  isHygieneType Boolean @default(false)
  dTimeMin      Int     @default(0)
  aTimeMin      Int     @default(0)
  procedureCategory String @default("BASIC_RESTORATIVE")
  // Sprint 1 \u2014 X-segment canonical primitive (Bible \u00a72.1)
  asstPreMin    Int     @default(0)
  doctorMin     Int     @default(0)
  asstPostMin   Int     @default(0)
  doctorContinuityRequired Boolean @default(false)
  office        Office  @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@index([officeId])
}

model ScheduleRule {
  id                String  @id @default(cuid())
  officeId          String  @unique
  npModel           String  @default("DOCTOR_ONLY")
  npBlocksPerDay    Int     @default(2)
  srpBlocksPerDay   Int     @default(2)
  hpPlacement       String  @default("MORNING")
  doubleBooking     Boolean @default(true)
  matrixing         Boolean @default(true)
  emergencyHandling String  @default("ACCESS_BLOCKS")
  office            Office  @relation(fields: [officeId], references: [id], onDelete: Cascade)
}

model ScheduleTemplate {
  id           String   @id @default(cuid())
  officeId     String
  name         String
  dayOfWeek    String
  weekType     String   @default("A")
  type         String   @default("WORKING")
  /// Loop 9: optional variant tag (e.g. "EOF", "Opt1", "Opt2").
  /// Null/empty = regular (non-variant) schedule for the day.
  variantLabel String?
  slotsJson    String   @default("[]")
  summaryJson  String   @default("[]")
  warningsJson String   @default("[]")
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  office       Office   @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@unique([officeId, dayOfWeek, weekType, type], name: "unique_working_schedule")
}

// Sprint 13 — Global Template Library
model TemplateLibraryItem {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  category    String   @default("GENERAL")
  isBuiltIn   Boolean  @default(false)
  slotsJson   String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Sprint 13 — Schedule Version History (auto-snapshot on every save)
model ScheduleVersion {
  id          String   @id @default(cuid())
  officeId    String
  dayOfWeek   String
  weekType    String   @default("A")
  slotsJson   String
  summaryJson String   @default("[]")
  label       String   @default("")
  createdAt   DateTime @default(now())
  office      Office   @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@index([officeId])
  @@index([officeId, dayOfWeek, weekType])
}

// Sprint 13 — Provider Time-Off / Absence Tracking
model ProviderAbsence {
  id         String   @id @default(cuid())
  providerId String
  officeId   String
  date       String
  reason     String   @default("")
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([officeId])
}

// Sprint 14 — Treatment Sequence Templates
model TreatmentSequence {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  isBuiltIn   Boolean  @default(false)
  stepsJson   String   @default("[]")
  createdAt   DateTime @default(now())
}

// Sprint 5 — Persisted Advisory artifact (one row per Generate). The four
// JSON blobs are the output of the advisory composer (see
// src/lib/engine/advisory/compose.ts). No FK to ScheduleTemplate so that the
// advisory survives template rebuilds; the UI joins by (templateId, officeId).
//
// Sprint 6 — Epic Q + Epic R additions:
//   documentRewriteJson      — optional Claude Opus rewrite (additive, original kept)
//   rewriteState             — "NONE" | "PENDING" | "ACCEPTED" | "REJECTED"
//   rewriteGeneratedAt       — when rewrite was produced
//   chosenVariant            — "GROWTH" | "ACCESS" | "BALANCED" | null
//   chosenVariantAt          — when variant was committed
//   chosenVariantHistoryJson — audit array of previous variant choices
model TemplateAdvisory {
  id              String   @id @default(cuid())
  templateId      String
  officeId        String
  generatedAt     DateTime @default(now())
  documentJson    String   @default("{}")
  scoreJson       String   @default("{}")
  variantsJson    String   @default("{}")
  reviewPlanJson  String   @default("{}")
  // Sprint 6 Epic Q — LLM rewrite (additive to documentJson)
  documentRewriteJson  String?
  rewriteState         String   @default("NONE")
  rewriteGeneratedAt   DateTime?
  // Sprint 6 Epic R — chosen variant (advisory metadata only; never
  // promoted to ScheduleTemplate.isActive in Sprint 6)
  chosenVariant            String?
  chosenVariantAt          DateTime?
  chosenVariantHistoryJson String   @default("[]")
  office          Office   @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([officeId])
  @@index([chosenVariant])
}

// Sprint 6 Epic P — Prior template upload + parse reference.
// Read-only — NEVER consumed by the generator. Exists solely to be re-scored
// by scoreTemplate() via the synthesize shim and to drive the delta view.
// See SPRINT-6-PLAN §4.2.
model PriorTemplate {
  id           String   @id @default(cuid())
  officeId     String
  uploadedAt   DateTime @default(now())
  filename     String
  fileHash     String
  sourceFormat String
  parseStatus  String   @default("OK")
  blockCount   Int      @default(0)
  matchedCount Int      @default(0)
  blocksJson   String   @default("[]")
  rawText      String?
  supersededBy String?
  office       Office   @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@index([officeId])
  @@index([officeId, uploadedAt])
}

// Sprint 6 Epic Q — LLM rewrite cache. Hash of (originalMarkdown + systemPromptVersion)
// dedupes repeat refinements. 30-day TTL (enforced at read time).
model AdvisoryRewriteCache {
  id           String   @id @default(cuid())
  hash         String   @unique
  rewrite      String
  createdAt    DateTime @default(now())
  systemPromptVersion String @default("1")

  @@index([hash])
  @@index([createdAt])
}

// Sprint 3 — Per-practice procedure length overrides (PRD-V4 FR-6).
// When a row exists for (officeId, blockTypeId), its x-segment values shadow
// the base BlockType row at generation time. The coordinator merges overrides
// once per generation call at the top of `generateSchedule()`, so there is
// no per-block DB read.
model ProcedureOverride {
  id          String   @id @default(cuid())
  officeId    String
  blockTypeId String
  asstPreMin  Int?
  doctorMin   Int?
  asstPostMin Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([officeId, blockTypeId], name: "unique_office_block_override")
}
