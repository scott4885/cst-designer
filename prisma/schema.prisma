generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite doesn't support enums or JSON, so we use String types
// Application code will validate these values

model Office {
  id            String   @id @default(uuid())
  name          String
  dpmsSystem    String   @map("dpms_system") // DENTRIX | OPEN_DENTAL | EAGLESOFT | DENTICON
  workingDays   String   @map("working_days") // JSON array of day strings
  timeIncrement Int      @default(10) @map("time_increment")
  feeModel      String   @map("fee_model") // UCR | PPO | MIXED
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  providers         Provider[]
  blockTypes        BlockType[]
  procedures        Procedure[]
  scheduleTemplates ScheduleTemplate[]
  scheduleRules     ScheduleRule[]

  @@map("offices")
}

model Provider {
  id           String   @id @default(uuid())
  officeId     String   @map("office_id")
  name         String
  providerId   String   @map("provider_id")
  role         String   // DOCTOR | HYGIENIST
  operatories  String   // JSON array of strings
  workingDays  String   @map("working_days") // JSON array of day strings
  workingStart String   @map("working_start")
  workingEnd   String   @map("working_end")
  lunchStart   String?  @map("lunch_start")
  lunchEnd     String?  @map("lunch_end")
  dailyGoal    Float    @map("daily_goal")
  hourlyRate   Float?   @map("hourly_rate")
  color        String   @default("#6b9bd1")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  office      Office       @relation(fields: [officeId], references: [id], onDelete: Cascade)
  rampUpGoals RampUpGoal[]
  timeSlots   TimeSlot[]

  @@index([officeId])
  @@map("providers")
}

model RampUpGoal {
  id         String   @id @default(uuid())
  providerId String   @map("provider_id")
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  dailyGoal  Float    @map("daily_goal")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("ramp_up_goals")
}

model BlockType {
  id            String   @id @default(uuid())
  officeId      String   @map("office_id")
  label         String
  description   String?
  minimumAmount Float?   @map("minimum_amount")
  appliesToRole String   @map("applies_to_role") // DOCTOR | HYGIENIST | BOTH
  durationMin   Int      @map("duration_min")
  durationMax   Int?     @map("duration_max")
  color         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  office    Office     @relation(fields: [officeId], references: [id], onDelete: Cascade)
  timeSlots TimeSlot[]

  @@index([officeId])
  @@map("block_types")
}

model Procedure {
  id            String   @id @default(uuid())
  officeId      String   @map("office_id")
  name          String
  duration      Int
  appliesToRole String   @map("applies_to_role") // DOCTOR | HYGIENIST
  typicalFee    Float?   @map("typical_fee")

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@index([officeId])
  @@map("procedures")
}

model ScheduleTemplate {
  id                 String   @id @default(uuid())
  officeId           String   @map("office_id")
  version            Int      @default(1)
  effectiveDate      DateTime? @map("effective_date")
  status             String   @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  generatedBy        String   @default("MANUAL") @map("generated_by") // MANUAL | AI | RULE_BASED
  generationMetadata String?  @map("generation_metadata") // JSON string
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  office       Office        @relation(fields: [officeId], references: [id], onDelete: Cascade)
  daySchedules DaySchedule[]

  @@index([officeId])
  @@map("schedule_templates")
}

model DaySchedule {
  id         String  @id @default(uuid())
  templateId String  @map("template_id")
  dayOfWeek  String  @map("day_of_week") // MONDAY | TUESDAY | etc.
  variant    String?

  template  ScheduleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  timeSlots TimeSlot[]

  @@index([templateId])
  @@map("day_schedules")
}

model TimeSlot {
  id            String  @id @default(uuid())
  dayScheduleId String  @map("day_schedule_id")
  time          String
  providerId    String? @map("provider_id")
  operatory     String?
  staffingCode  String? @map("staffing_code") // D | A | H
  blockTypeId   String? @map("block_type_id")
  blockLabel    String? @map("block_label")
  isBreak       Boolean @default(false) @map("is_break")

  daySchedule DaySchedule @relation(fields: [dayScheduleId], references: [id], onDelete: Cascade)
  provider    Provider?   @relation(fields: [providerId], references: [id])
  blockType   BlockType?  @relation(fields: [blockTypeId], references: [id])

  @@index([dayScheduleId])
  @@index([providerId])
  @@map("time_slots")
}

model ScheduleRule {
  id        String @id @default(uuid())
  officeId  String @map("office_id")
  ruleType  String @map("rule_type") // NP_MODEL | HP_PLACEMENT | etc.
  ruleValue String @map("rule_value") // JSON string

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@index([officeId])
  @@map("schedule_rules")
}
