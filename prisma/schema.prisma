generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Office {
  id            String   @id @default(cuid())
  name          String
  dpmsSystem    String   @default("OPEN_DENTAL")
  workingDays   String   @default("[]")
  timeIncrement Int      @default(10)
  feeModel      String   @default("UCR")
  operatories   String   @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  providers     Provider[]
  blockTypes    BlockType[]
  rules         ScheduleRule?
  templates     ScheduleTemplate[]
}

model Provider {
  id              String  @id @default(cuid())
  officeId        String
  name            String
  role            String
  operatories     String  @default("[]")
  columns         Int     @default(1)
  workingStart    String  @default("07:00")
  workingEnd      String  @default("18:00")
  lunchStart      String  @default("13:00")
  lunchEnd        String  @default("14:00")
  dailyGoal       Float   @default(0)
  color           String  @default("#666")
  seesNewPatients Boolean @default(true)
  office          Office  @relation(fields: [officeId], references: [id], onDelete: Cascade)
}

model BlockType {
  id            String  @id @default(cuid())
  officeId      String
  label         String
  description   String  @default("")
  minimumAmount Float   @default(0)
  appliesToRole String
  durationMin   Int     @default(30)
  durationMax   Int     @default(30)
  color         String  @default("#666")
  isHygieneType Boolean @default(false)
  office        Office  @relation(fields: [officeId], references: [id], onDelete: Cascade)
}

model ScheduleRule {
  id                String  @id @default(cuid())
  officeId          String  @unique
  npModel           String  @default("DOCTOR_ONLY")
  npBlocksPerDay    Int     @default(2)
  srpBlocksPerDay   Int     @default(2)
  hpPlacement       String  @default("MORNING")
  doubleBooking     Boolean @default(false)
  matrixing         Boolean @default(true)
  emergencyHandling String  @default("ACCESS_BLOCKS")
  office            Office  @relation(fields: [officeId], references: [id], onDelete: Cascade)
}

model ScheduleTemplate {
  id           String   @id @default(cuid())
  officeId     String
  name         String
  dayOfWeek    String
  slotsJson    String   @default("[]")
  summaryJson  String   @default("[]")
  warningsJson String   @default("[]")
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  office       Office   @relation(fields: [officeId], references: [id], onDelete: Cascade)
}
