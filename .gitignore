# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.production
.env.*.local
# but keep the example template
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# prisma
prisma/*.db

# SQLite data
data/*.db
data/*.db-journal
data/

# Local Netlify folder (deprecated — no longer a deploy target)
.netlify

# OpenNext / Cloudflare build artifacts (deprecated adapter, kept out of git)
.open-next/
.wrangler/
