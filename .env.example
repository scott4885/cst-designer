# Copy this file to .env.local for local development.
# Do NOT commit real secrets to .env — use .env.local (gitignored) for any tokens.

# SQLite database path (Prisma)
DATABASE_URL=file:./data/schedules.db

# Node environment
# NODE_ENV=development

# ─── Sprint 3 — V2 schedule grid feature flag ─────────────────────
#
# NEXT_PUBLIC_SCHEDULE_V2
#   Flips the schedule canvas between the legacy grid
#   (src/components/schedule/ScheduleGrid.tsx) and the V2 multi-row
#   X-segment grid (src/components/schedule/v2/ScheduleGrid.tsx).
#
#   Sprint 3 default: `1` (V2 grid is the default).
#   Rollback: set to `0` to restore the legacy grid — no code changes.
#
NEXT_PUBLIC_SCHEDULE_V2=1

# CST_V4_ENABLED
#   Master V4 feature flag — Sprint Plan §5.2. Gates the Coolify staging
#   deployment. Off = V3 behaviour. On = full V4 stack.
#
CST_V4_ENABLED=1

